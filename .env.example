# ===== Databricks =====
DATABRICKS_SERVER_HOSTNAME=seu-hostname.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/seu-warehouse-id
DATABRICKS_TOKEN=dapi_seu_token_aqui

# Catalogo e schema de destino no Databricks
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=default

# ===== MySQL =====
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=sua_senha
MYSQL_DATABASE=seu_banco
